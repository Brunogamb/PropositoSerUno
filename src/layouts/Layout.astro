---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<title>{title}</title>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="description" content="Propósito Ser Uno: un espacio de crecimiento personal y espiritual para alcanzar tu máximo potencial. Descubre herramientas, recursos y comunidad para transformar tu vida y vivir con propósito.">
		<meta name="author" content="Propósito Ser Uno">
		<meta name="robots" content="index, follow">
		<meta property="og:locale" content="es_AR">
		<meta property="og:title" content="Propósito Ser Uno">
		<meta property="og:description" content="Propósito Ser Uno: un espacio de crecimiento personal y espiritual para alcanzar tu máximo potencial. Descubre herramientas, recursos y comunidad para transformar tu vida y vivir con propósito.">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		</script>
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style is:global>
:root {
    --brand-900: #260090;
    --brand-900-rgb: 41, 22, 111;
    --brand-800: #3a2a8f;
    --brand-800-rgb: 58, 42, 143;
    --brand-700: #784bf2;
    --brand-700-rgb: 81, 69, 182;

    --brand-orange: #ff9854; 
    --brand-orange-rgb: 254, 152, 83;
	--brand-orange-dark: #fe6600;
	--brand-orange-dark-rgb: 254, 102, 0;
    --brand-orange-hover: #e08600;
    --brand-gold: #ffc107; 
    --brand-gold-rgb: 255, 193, 7;

    --bg: #f1f1f1;
    --bg-muted: #ededed; 
    --bg-light: #f9f9f9;
    --white: #ffffff;
    --white-rgb: 255, 255, 255;
    --text: #232323;
    --muted: #e4e0fa;

    --accent: #a793e7;
    --accent-rgb: 167, 147, 231;

    --instagram: #E1306C;
    --whatsapp: #25D366;
    --dark-bg: #0f172a;

    --shadow-sm: 0 0 8px 4px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 0 8px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 2px 10px 0 rgba(0, 0, 0, 0.18);
    --shadow-top: 0 -4px 8px rgba(0, 0, 0, 0.05);

    --radius-xs: 2px;
    --radius-sm: 8px;
    --radius-md: 16px;
    --radius-full: 50%;

    --blur-sm: 6px;
    --blur-md: 8px;

	--lora-font: 'Lora Variable', serif, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont;
    --open-sans-font: 'Open Sans Variable', sans-serif, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
	overflow-y: scroll;
}

body {
	font-family: 'Lora Variable', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
	background-color: var(--bg);
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    overflow-x: hidden;
	color: var(--white);
}

@font-face {
		font-family: 'Lora Variable';
		src: url('/fonts/Lora-VariableFont_wght.woff2') format('truetype');
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: 'Open Sans Variable';
		src: url('/fonts/OpenSans-VariableFont_wdth,wght.woff2') format('truetype');
		font-style: normal;
		font-display: swap;
	}

header, main, footer {
    width: 100%;
}

a {
    text-decoration: none;
    color: inherit;
}

main {
	flex: 1;
}
</style>