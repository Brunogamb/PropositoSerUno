---
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/sections/ScrollToTop.astro';

const {
	title = 'Propósito Ser Uno | Conquistando salud y bienestar cada día',
	description = 'Propósito Ser Uno: un espacio pensado para acompañarte en tu proceso de salud. Compartimos un método para complementar activamente cualquier tratamiento de salud que estés realizando.',
	image = '/PropositoSerUno/favicon.png',
	imageAlt = 'Propósito Ser Uno - Conquistando salud y bienestar cada día',
	type = 'website',
	siteName = 'Propósito Ser Uno',
	locale = 'es_AR',
} = Astro.props;

const siteBase = String(Astro.site ?? 'https://propositoseruno.com').replace(/\/$/, '');
const canonical = `${siteBase}${Astro.url?.pathname ?? '/'}`;
const ogImage = image.startsWith('http') ? image : `${siteBase}${image.startsWith('/') ? image : `/${image}`}`;
const language = locale.replace('_', '-');
const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		"url": siteBase,
		"name": siteName,
		"description": description,
		"publisher": {
			"@type": "Organization",
			"name": siteName,
			"url": siteBase,
		},
		"inLanguage": language,
	},
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		"url": canonical,
		"name": title,
		"description": description,
		"isPartOf": {
			"@type": "WebSite",
			"name": siteName,
			"url": siteBase,
		},
		"inLanguage": language,
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": canonical,
		},
	},
];
---

<!doctype html>
<html lang="es">
	<head>
		<title>{title}</title>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="description" content={description}>
		<meta name="author" content={siteName}>
		<meta name="theme-color" content="#ff9854">
		<meta name="color-scheme" content="light">
		<meta name="supported-color-schemes" content="light">
		<meta name="format-detection" content="telephone=no,email=no,address=no">
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
		<link rel="canonical" href={canonical}>
		<link rel="alternate" href={canonical} hreflang="es-AR">
		<link rel="alternate" href={canonical} hreflang="es">
		<link rel="alternate" href={canonical} hreflang="x-default">
		<meta property="og:locale" content={locale}>
		<meta property="og:locale:alternate" content="es_AR">
		<meta property="og:type" content={type}>
		<meta property="og:title" content={title}>
		<meta property="og:description" content={description}>
		<meta property="og:url" content={canonical}>
		<meta property="og:site_name" content={siteName}>
		<meta property="og:image" content={ogImage}>
		<meta property="og:image:secure_url" content={ogImage}>
		<meta property="og:image:alt" content={imageAlt}>
		<meta property="og:image:type" content="image/png">
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">
		<meta name="twitter:card" content="summary_large_image">
		<meta name="application-name" content={siteName}>
		<meta name="apple-mobile-web-app-title" content={siteName}>
		<meta name="twitter:title" content={title}>
		<meta name="twitter:description" content={description}>
		<meta name="twitter:image" content={ogImage}>
		<meta name="twitter:image:alt" content={imageAlt}>
		<link rel="icon" type="image/x-icon" href="/PropositoSerUno/favicon.ico" />
		<link rel="icon" type="image/png" href="/PropositoSerUno/favicon.png" />
		<link rel="preload" as="font" href="/PropositoSerUno/fonts/Lora-VariableFont_wght.woff2" type="font/woff2" crossorigin>
		<link rel="preload" as="font" href="/PropositoSerUno/fonts/OpenSans-VariableFont_wdth,wght.woff2" type="font/woff2" crossorigin>
		<script type="application/ld+json">{JSON.stringify(jsonLd)}</script>
	</head>
	<body>
		<script>
			document.documentElement.style.colorScheme = 'light';
		</script>
		<main>
			<slot />
		</main>
		<ScrollToTop />
		<Footer />
	</body>
</html>

<style is:global>
:root {
	color-scheme: light;

    --brand-900: #260090;
    --brand-900-rgb: 41, 22, 111;
    --brand-800: #3a2a8f;
    --brand-800-rgb: 58, 42, 143;
    --brand-700: #784bf2;
    --brand-700-rgb: 81, 69, 182;
	--button-primary: #5d28f0;

	--brand-orange-light: #ffccaa;
    --brand-orange: #ff9854; 
    --brand-orange-rgb: 254, 152, 83;
	--brand-orange-dark: #fe6600;
	--brand-orange-dark-rgb: 254, 102, 0;
	--brand-orange-hover: #db5800;
	--brand-orange-darker: #b34800;

    --bg-section: #ebe8f5;
    --bg-section-orange: #feccab;
	--bg-section-brand-light: #bda9f5;
    --white: #fff;
    --white-rgb: 255, 255, 255;
    --text: #191919;
	--text-light: #444;
    --muted: #eee;

    --dark-bg: #0f172a;

	--lora-font: 'Lora Variable', serif, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont;
    --open-sans-font: 'Open Sans Variable', sans-serif, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    color-scheme: light !important;
}

html {
	overflow-y: scroll;
    color-scheme: light !important;
    background-color: var(--brand-orange) !important;
}

body {
	font-family: 'Lora Variable', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
	background-color: var(--brand-orange) !important;
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    overflow-x: hidden;
	color: var(--white) !important;
	color-scheme: light !important;
}

@media (prefers-color-scheme: dark) {
	html,
	body {
		color-scheme: light !important;
		background-color: var(--brand-orange) !important;
		color: var(--white) !important;
	}
}

@font-face {
	font-family: 'Lora Variable';
	src: url('/PropositoSerUno/fonts/Lora-VariableFont_wght.woff2') format('woff2');
	font-style: normal;
	font-display: swap;
}

@font-face {
	font-family: 'Open Sans Variable';
	src: url('/PropositoSerUno/fonts/OpenSans-VariableFont_wdth,wght.woff2') format('woff2');
	font-style: normal;
	font-display: swap;
}

header, main, footer {
    width: 100%;
}

a {
    text-decoration: none;
    color: inherit;
}

main {
	flex: 1;
}
</style>