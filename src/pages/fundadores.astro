---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/sections/page6/Hero.astro';
import Team from '../components/sections/page6/Team.astro';
import PreFooter from '../components/sections/page3/PreFooter.astro';
---

<Layout
	title="Fundadores Propósito Ser Uno | Un espacio creado desde la experiencia, el compromiso y la vocación de acompañar a otros."
	description="Conoce a los fundadores de Propósito Ser Uno, su visión de crecimiento espiritual y el propósito detrás de esta comunidad transformadora."
	image="/favicon.png"
	imageAlt="Fundadores Propósito Ser Uno - Un espacio creado desde la experiencia, el compromiso y la vocación de acompañar a otros."
>
    <Header variant='white'/>
    <Hero />
    <Team />
    <PreFooter bgColor="var(--bg-section)"/>
</Layout>