---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/sections/page4/Hero.astro';
import MembershipFeatures from '../components/sections/page4/MembershipFeatures.astro';
import CommunityGroups from '../components/sections/page4/CommunityGroups.astro';
import CommunityVision from '../components/sections/page4/CommunityVision.astro';
import PreFooter from '../components/sections/page3/PreFooter.astro';
---

<Layout
	title="Comunidad Propósito Ser Uno | Espacios donde el proceso de recuperación y bienestar se convierte en una experiencia colectiva, humana y transformadora."
	description="Únete a Propósito Ser Uno una comunidad comprometida con impulsar la evolución mental y el desarrollo espiritual en el mundo."
	image="/PropositoSerUno/favicon.png"
	imageAlt="Comunidad Propósito Ser Uno - Espacios donde el proceso de recuperación y bienestar se convierte en una experiencia colectiva, humana y transformadora."
>
    <Header variant="orangeLight"/>
    <Hero />
    <MembershipFeatures />
    <CommunityGroups />
    <CommunityVision />
    <PreFooter bgColor="var(--bg-section)"/>
</Layout>