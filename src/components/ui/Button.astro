---
interface Props {
    text: string;
    href: string;
    variant?: 'primary' | 'secondary' | 'outline';
    className?: string;
}

const { text, href, variant = 'primary', className = '' } = Astro.props;

const variantStyles = {
    primary: 'button-primary text-white border hover:bg-brand-800',
    secondary: 'bg-brand-orange-dark text-white border hover:bg-brand-orange-hover',
    outline: 'bg-transparent text-brand-700 border hover:bg-brand-700 hover:text-white'
};

const baseStyles = "inline-block px-10 py-3 rounded-full font-medium transition-all duration-300 border-2 text-center min-w-[200px]";
---

<a href={href} class={`${baseStyles} ${variantStyles[variant]} ${className}`}>
    {text}
</a>

<style>
    .inline-block { 
        display: inline-block; 
    }

    .px-10 { 
        padding-left: 34px; 
        padding-right: 34px; 
    }

    .py-3 { 
        padding-top: 10px;
        padding-bottom: 12px; 
    }

    .rounded-full { 
        border-radius: 9999px; 
    }

    .font-medium { 
        font-weight: 500; 
    }

    .text-center { 
        text-align: center;
        font-family: var(--open-sans-font);
        font-size: 26px;
    }

    .transition-all { 
        transition: all 0.3s ease; 
    }

    .border { 
        border: 3px solid var(--white);
    }
    
    .bg-brand-700 { 
        background-color: var(--brand-700); 
    }

    .button-primary { 
        background-color: var(--button-primary); 
    }

    .bg-brand-orange-dark { 
        background-color: var(--brand-orange-dark); 
    }
    
    .text-white { 
        color: var(--white); 
    }

    .text-brand-700 { 
        color: var(--brand-700); 
    }

    @media (hover: hover) {
        a:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }
    }
</style>