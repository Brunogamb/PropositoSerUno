---
interface Props {
    text: string;
    href: string;
    variant?: 'primary' | 'secondary' | 'outline';
    className?: string;
}

const { text, href, variant = 'primary', className = '' } = Astro.props;

const variantStyles = {
    primary: 'btn-primary',
    secondary: 'btn-secondary',
    outline: 'btn-outline'
};

const baseStyles = "btn-base";
---

<a href={href} class={`${baseStyles} ${variantStyles[variant]} ${className}`}>
    {text}
</a>

<style>
    .btn-base { 
        display: flex; 
        padding-left: 34px; 
        padding-right: 34px; 
        padding-top: 10px;
        padding-bottom: 12px; 
        border-radius: 9999px; 
        font-weight: 500; 
        text-align: center;
        font-family: var(--open-sans-font);
        font-size: 26px;
        transition: all 0.3s ease; 
        min-width: 200px;
        text-decoration: none;
        border: 3px solid var(--white);
    }

    .btn-primary { 
        background-color: var(--button-primary); 
        color: var(--white); 
    }

    .btn-secondary { 
        background-color: var(--brand-orange-dark); 
        color: var(--white); 
    }

    .btn-outline { 
        background-color: var(--white); 
        color: var(--brand-700); 
        border: 3px solid var(--brand-700);
    }

    @media (hover: hover) {
        .btn-base:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }

        .btn-primary:hover {
            background-color: var(--brand-800);
        }

        .btn-secondary:hover {
            background-color: var(--brand-orange-hover);
        }

        .btn-outline:hover {
            background-color: var(--muted);
        }
    }
</style>