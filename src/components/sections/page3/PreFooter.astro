---
import { Image } from 'astro:assets';
import Logo from '../../../assets/Logo.webp';

const { bgColor = 'var(--white)' } = Astro.props;
---

<section class="prefooter" style={{ backgroundColor: bgColor }}>
    <div class="container">
        <div class="content">
            <a href="/PropositoSerUno/"><Image src={Logo} alt="Logo de Propósito Ser Uno" class="logo" loading="lazy"/></a>
            <h2>Comunidad en formación, hacia una organización civil sin fines de lucro</h2>
        </div>
    </div>
</section>

<style>
    .prefooter {
        padding: 85px 20px 20px 20px;
        color: var(--text);
        display: flex;
        justify-content: center;
    }

    .container {
        max-width: 1100px;
        width: 100%;
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 10px;
    }

    .content h2 {
        font-family: var(--open-sans-font);
        font-size: 28px;
        line-height: 1.6;
        font-weight: 400;
        color: var(--text-light);
        text-align: left;
    }

    .logo {
        width: 350px;
        height: auto;
    }

    a {
        width: fit-content;
    }

    @media (max-width: 768px) {
        .prefooter { 
            padding: 60px 20px; 
        }

        .content h2 {
            font-size: 21px;
            line-height: 1.6;
            font-weight: 600;
            color: var(--text-light);
            text-align: left;
        }

        .logo {
            width: 300px;
            height: auto;
        }
    }
</style>