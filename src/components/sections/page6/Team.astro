---
import { Image } from 'astro:assets';
import robertoudrisar from '../../../assets/Team/robertoudrisar.webp';
import yaninachami from '../../../assets/Team/yaninachami.webp';
import marceloudrisar from '../../../assets/Team/marceloudrisar.webp';
import silviasoria from '../../../assets/Team/silviasoria.webp';
import amaliaherrlein from '../../../assets/Team/amaliaherrlein.webp';

import Button from '../../../components/ui/Button.astro';

const team = [
    {
        name: "Roberto Udrisar",
        roles: [
        "Investigador, Escritor y Disertante.",
        "Creador del taller Logros.",
        "Director de Propósito Ser Uno."
        ],
        image: robertoudrisar
    },
    {
        name: "Yanina Chami",
        roles: [
        "Terapeuta Holístico Integral",
        "Maestría en Canalización Angelical.",
        "Formación en Merkaba."
        ],
        image: yaninachami
    },
    {
        name: "Marcelo Udrisar",
        roles: [
        "Diseñador gráfico y publicista.",
        "Emprendedor, Investigador.",
        "Encargado ejecutivo de PSU."
        ],
        image: marceloudrisar
    },
    {
        name: "Silvia Soria",
        roles: [
        "Descodificadora Biológica Transgeneracional y Terapeuta de terapias de integración.",
        "Operador de Bio Well.",
        "Facilitadora de Biodanza."
        ],
        image: silviasoria
    },
    {
        name: "Analía Herrlein",
        roles: [
        "Master Coach, Facilitador de Procesos de cambio personales y de equipos.",
        "Educadora de Padres en Disciplina Positiva en la Familia y en Educación Consciente."
        ],
        image: amaliaherrlein
    }
];
---

<section class="team">
    <div class="container">
        <h2 class="main-quote">
        Un espacio creado desde la experiencia, el compromiso y la vocación de acompañar a otros.
        </h2>

        <div class="content">
            <p class="first-paragraph">
                Creemos en el poder de cada persona para sanar y transformar su vida. <strong>Nuestra misión</strong> es acompañar e inspirar procesos de recuperación y bienestar.
            </p>

            <div class="team-list">
                {team.map((member) => (
                    <article class="member-card">
                    <div class="image-wrapper">
                        <Image src={member.image} alt={member.name} class="member-photo" loading="lazy" width={200} height={200} />
                    </div>
                    <div class="member-info">
                        <h3>{member.name}</h3>
                        <ul>
                        {member.roles.map((role) => (
                            <li>{role}</li>
                        ))}
                        </ul>
                    </div>
                    </article>
                ))}
            </div>
            <p class="indent0">Propósito Ser Uno nace desde la convicción profunda de que cada persona puede recuperar y fortalecer cada área de su vida cuando decide involucrarse activamente en su proceso de recuperación y desarrollo personal.</p>
            <p>Sabemos que muchas veces ese camino puede volverse confuso, solitario o difícil de sostener. Por eso creamos este espacio para acompañar y acercar herramientas basadas en conocimientos científicos actuales, integradas con el desarrollo espiritual </p>
            <p>No ofrecemos soluciones mágicas, sino un camino posible y real, basado en la práctica, la constancia y la participación consciente.</p>
            <p>Si sentís que este puede ser tu momento, te invitamos a dar el primer paso y descubrir lo que este espacio puede aportar a tu vida. Hacerte miembro no implica costos de ingreso ni cuotas mensuales. La organización se sostiene gracias al aporte voluntario de sus miembros, que surge de la posibilidad y la consciencia de cada participante.</p>

        </div>

        <div class="actions">
            <Button variant="primary" text="Hazte miembro" href="/PropositoSerUno/membresia" />
        </div>

    </div>
</section>

<style>
    .team {
        background-color: var(--white);
        padding: 50px 20px 80px;
        display: flex;
        justify-content: center;
        color: var(--text);
    }

    .container {
        max-width: 800px;
        width: 100%;
        text-align: center;
    }

    .main-quote {
        font-family: var(--lora-font);
        font-size: 35px;
        line-height: 1.4;
        font-weight: 400;
        margin-bottom: 30px;
        color: var(--text);
        text-wrap: balance;
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 10px;
        text-align: left;
        margin-bottom: 45px;
    }

    .first-paragraph {
        font-family: var(--open-sans-font);
        font-size: 26px;
        line-height: 1.6;
        font-weight: 400;
        color: var(--text);
        text-align: left;
        text-indent: 0;
    }

    p {
        font-family: var(--open-sans-font);
        font-size: 22px;
        line-height: 1.6;
        font-weight: 400;
        color: var(--text-light);
        text-indent: 20px; 
        text-align: left;
    }

    .indent0 {
        text-indent: 0;
    }

    .team-list {
        display: flex;
        flex-direction: column;
        gap: 27px;
        margin: 40px 0 30px;
    }

    .member-card {
        display: flex;
        align-items: end; 
        gap: 25px;
    }

    .image-wrapper {
        flex-shrink: 0;
        width: 200px;
        height: 200px;
        border: 1px solid var(--brand-900); 
        aspect-ratio: 1 / 1;
    }

    .member-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .member-info {
        display: flex;
        flex-direction: column;
        justify-content: top;
    }

    .member-info h3 {
        font-family: var(--lora-font);
        font-size: 28px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 5px;
        line-height: 1.2;
    }

    .member-info ul {
        list-style: none;
    }

    .member-info li {
        font-family: var(--open-sans-font);
        font-size: 22px;
        line-height: 1.4;
        font-weight: 400;
        color: var(--text);
        margin-bottom: 3px;
        text-wrap: balance;
    }

    .actions {
        display: flex;
        justify-content: center;
        width: 100%;
    }

    @media (max-width: 768px) {
        .team {
            padding: 40px 16px;
        }

        .main-quote {
            font-size: 28px;
        }

        .content p {
            font-size: 18px;
            line-height: 1.6;
            text-indent: 0;
        }

        .team-list {
            gap: 20px;
        }

        .member-card {
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        .image-wrapper {
            width: min(280px, 100%);
            height: auto;
            overflow: hidden;
        }

        .member-photo {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .member-info {
            width: 100%;
            align-items: center;
        }

        .member-info h3 {
            font-size: 21px;
            text-align: center;
            margin-bottom: 10px;
        }

        .member-info ul {
            padding-left: 0;
            text-align: left;
            width: 100%;
            margin-bottom: 20px;
        }

        .member-info li {
            font-size: 18px;
            line-height: 1.6;
            text-align: center;
        }
    }
</style>