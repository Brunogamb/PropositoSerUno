---
import heroImage from '../../assets/HeroBackground.webp';
---

<section class="hero">
    <div class="text">
        <h1>Conquistando <br> salud y bienestar cada día</h1>
        <h2>Iniciativa independiente sin fines de lucro</h2>
    </div>
</section>

<style define:vars={{ heroBg: `url(${heroImage.src})` }}>
    h1 {
        font-weight: 600;
        font-size: 71px;
        margin-bottom: 40px;
    }
    
    h2 {
        font-weight: 400;
        font-size: 34px;
    }

    section {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start; 
        text-align: center;
        width: 100%;
        aspect-ratio: 16/11;
        padding: 80px 20px; 
        background-image: var(--heroBg);
        background-repeat: no-repeat;
        background-size: cover;
        background-position: bottom center;;
        color: var(--white);
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 42px;
        }
        
        h2 {
            font-size: 22px;
        }
    }
</style>