        color: var(--brand-900);
        text-align: center;
    }

    h2 {
        font-family: var(--open-sans-font);
        font-size: 21px;
        line-height: 1.6;
        font-weight: 400;
        color: var(--text);
        max-width: 600px;
        text-align: center;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 47px;
        }
