---
const faqs = [
    {
        question: "¿Es Propósito Ser Uno fiable?",
        answer: "Sí, Propósito Ser Uno se basa en principios de integridad, transparencia y compromiso con el bienestar integral de cada persona."
    },
    {
        question: "¿Qué hace Propósito Ser uno?",
        answer: "Todos nuestros contenidos y programas están elaborados a partir de aportes de las ciencias de vanguardia —como la neurociencia, la epigenética y la psicoinmunoneuroendocrinología— junto con enseñanzas espirituales milenarias y prácticas orientadas al bienestar integral. Además, contamos con una comunidad activa de acompañamiento y un sistema seguro para el acceso, las membresías y la gestión de la información personal."
    },
    {
        question: "¿Cuánto cuesta Propósito Ser Uno?",
        answer: ""
    },
    {
        question: "¿Qué incluye la membresía de Propósito Ser Uno?",
        answer: ""
    },
    {
        question: "¿Para qué me sirve unirme a Propósito Ser Uno?",
        answer: ""
    },
    {
        question: "¿Por qué el programa de Propósito Ser Uno funciona?",
        answer: ""
    },
    {
        question: "¿Quiénes son los creadores de Propósito Ser Uno?",
        answer: ""
    },
    {
        question: "¿Es Propósito Ser Uno para mí?",
        answer: ""
    }
];
---

<section class="faq">
    <div class="container">
        <span class="eyebrow">PREGUNTAS FRECUENTES</span>

        <div class="faq-list">
        {faqs.map(({ question, answer }) => (
            <details class="faq-item">
            <summary>
                <span class="icon">+</span>
                <span class="question-text">{question}</span>
            </summary>
            <div class="answer">
                <p>{answer}</p>
            </div>
            </details>
        ))}
        </div>
    </div>
</section>

<style>
    .faq {
        background-color: var(--white);
        padding: 60px 20px 40px 20px;
        color: var(--text);
        display: flex;
        justify-content: center;
    }

    .container {
        max-width: 800px;
        width: 100%;
    }

    .eyebrow {
        display: block;
        font-family: var(--open-sans-font);
        color: var(--brand-700);
        font-weight: 600;
        font-size: 18px;
        letter-spacing: 1px;
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .faq-item {
        border-bottom: 1px solid #eee;
        padding: 15px 0;
        cursor: pointer;
    }

    .faq-item summary {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 15px;
        font-family: var(--open-sans-font);
        font-size: 21px;
        font-weight: 400;
        color: var(--text);
    }

    .faq-item summary::-webkit-details-marker {
        display: none;
    }

    .icon {
        font-size: 24px;
        font-weight: 300;
        transition: transform 0.4s ease;
        display: inline-block;
        color: var(--brand-700);
    }

    .faq-item[open] .icon {
        transform: rotate(45deg);
        color: var(--brand-orange-dark);
    }

    .question-text {
        flex: 1;
    }

    .answer {
        padding: 20px 0 10px 40px;
        overflow: hidden;
        animation: slideDown 0.3s ease-out;
    }

    .answer p {
        font-family: var(--open-sans-font);
        font-size: 18px;
        line-height: 1.6;
        font-weight: 300;
        color: #555;
    }

    @keyframes slideDown {
        from {
        opacity: 0;
        transform: translateY(-10px);
        }
        to {
        opacity: 1;
        transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .faq-item summary {
        font-size: 18px;
        }
        .answer {
        padding-left: 30px;
        }
    }
</style>