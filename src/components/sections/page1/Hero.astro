---
import heroImage from '/src/assets/Hero/HeroBackground.webp';
---

<section class="hero">
    <div class="text">
        <h1>Conquistando <br> salud y bienestar cada día</h1>
        <h2>Iniciativa independiente sin fines de lucro</h2>
    </div>

    <div class="video-container" id="video-wrapper">
        <video 
            id="hero-video" 
            class="hero-video"
            autoplay 
            muted 
            loop 
            playsinline
            preload="metadata"
            controlslist="nodownload"
        >
            <source src={'/PropositoSerUno/HeroVideo.webm'} type="video/webm" />
            <source src={'/PropositoSerUno/HeroVideo.mp4'} type="video/mp4" />
            Tu navegador no soporta el elemento video
        </video>

        <div class="custom-controls-bar initial-hide" id="custom-controls">
            <button id="play-toggle-bar" class="bar-btn" aria-label="Pausar video">
                <svg id="icon-pause-bar" class="control-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <rect x="6" y="4" width="4" height="16"></rect>
                    <rect x="14" y="4" width="4" height="16"></rect>
                </svg>
                <svg id="icon-play-bar" class="control-icon hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="6 4 20 12 6 20 6 4"></polygon>
                </svg>
            </button>

            <div class="progress-container" id="progress-container">
                <div class="progress-bar-bg">
                    <div class="progress-current" id="progress-fill"></div>
                </div>
            </div>

            <div class="right-controls">
                <span class="time-display" id="time-display">0:00</span>
                
                <button id="audio-toggle-bar" class="bar-btn" aria-label="Silenciar video">
                    <svg id="icon-playing-bar" class="control-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 5L6 9H2v6h4l5 4V5z"></path>
                        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                    </svg>
                    <svg id="icon-muted-bar" class="control-icon hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 5L6 9H2v6h4l5 4V5z"></path>
                        <line x1="22" y1="9" x2="16" y2="15"></line>
                        <line x1="16" y1="9" x2="22" y2="15"></line>
                    </svg>
                </button>

                <button id="fullscreen-toggle-bar" class="bar-btn" aria-label="Pantalla completa">
                    <svg id="icon-fullscreen-enter" class="control-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
                    </svg>
                    <svg id="icon-fullscreen-exit" class="control-icon hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 14h6v6m10-6h-6v6M4 10h6V4m10 6h-6V4"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</section>

<style define:vars={{ heroBg: `url(${heroImage.src})` }}>
    .hero {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        width: 100%;
        height: 882px;  
        padding: 70px 20px 0 20px;
        color: var(--white);
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: var(--heroBg);
        background-repeat: no-repeat;
        background-size: 100% 882px;
        background-position: center top; 
        z-index: 0;
    }

    .text {
        position: relative;
        z-index: 2;
    }

    h1 {
        font-weight: 600;
        font-size: clamp(42px, 5vw, 63px); 
        margin-bottom: 35px;
        line-height: 1.5;
    }
    
    h2 {
        font-weight: 400;
        font-size: clamp(22px, 2.5vw, 33px);
    }

    .video-container {
        position: absolute;
        top: 390px;
        width: 100%;
        max-width: 820px;
        aspect-ratio: 16 / 9;
        z-index: 10;
        cursor: pointer;
        border-radius: 20px;
    }

    .video-container.hide-controls {
        cursor: none;
    }

    .hero-video {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .custom-controls-bar {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 34px;
        background: rgba(20, 15, 38, 0.55);
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 14px;
        z-index: 25;
        border-radius: 0 0 20px 20px;
        opacity: 1;
        transform: translateY(0);
        transition: all 0.4s ease;
    }

    .custom-controls-bar.initial-hide {
        opacity: 0;
        transform: translateY(15px);
        pointer-events: none;
    }

    .custom-controls-bar.fade-out {
        opacity: 0;
        pointer-events: none;
    }

    .bar-btn {
        background: none;
        border: none;
        color: var(--white);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4px;
        transition: transform 0.2s;
    }

    .control-icon {
        width: 18px;
        height: 18px;
    }

    .progress-container {
        flex-grow: 1;
        display: flex;
        align-items: center;
        height: 100%;
        cursor: pointer;
    }

    .progress-bar-bg {
        width: 100%;
        height: 4px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 2px;
        position: relative;
        transition: height 0.15s ease;
    }


    .progress-current {
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 0%;
        background: var(--white);
        border-radius: 2px;
    }

    .right-controls {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .time-display {
        font-family: sans-serif;
        font-size: 12px;
        color: var(--white);
        user-select: none;
    }

    .hidden {
        display: none;
    }

    #video-wrapper:fullscreen {
        max-width: 100vw;
        width: 100vw;
        height: 100vh;
        aspect-ratio: auto;
        border-radius: 0;
    }

    #video-wrapper:fullscreen .hero-video {
        object-fit: contain; 
    }

    #video-wrapper:fullscreen .custom-controls-bar {
        border-radius: 0;
        bottom: 12px;
        width: calc(100% - 24px);
        left: 12px;
        border-radius: 10px;
    }

    #video-wrapper:-webkit-full-screen {
        max-width: 100%;
        width: 100% ;
        height: 100% ;
        border-radius: 0;
    }

    #video-wrapper:-webkit-full-screen .hero-video {
        object-fit: contain;
    }

    #video-wrapper:-webkit-full-screen .custom-controls-bar {
        border-radius: 0;
        bottom: 12px;
        width: calc(100% - 24px);
        left: 12px;
        border-radius: 10px;
    }

    @media (hover: hover) {
        .progress-container:hover .progress-bar-bg {
            height: 6px;
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 74px 16px 40px;
            height: calc(270px + 160px + 53.44vw + 40px);
            min-height: auto;
            
        }

        .video-container {
            position: absolute;
            width: 95%;
            top: 270px;
            max-width: 520px;
            margin-top: 160px;
        }

        .hero-video {
            border-radius: 12px;
        }

        .hero::before {
            background-size: 120% 882px;
            background-position: center -120px; 
        }

        h1 {
            line-height: 1.4;
            margin-bottom: 30px;
            font-size: 36px;
        }

        h2 {
            font-size: 22px;
            line-height: 1.5;
            text-wrap: balance;
        }
    }
</style>

<script type="module">
    const videoWrapper = document.getElementById('video-wrapper');
    const video = document.getElementById('hero-video');
    const controlsBar = document.getElementById('custom-controls');
    
    const playBtnBar = document.getElementById('play-toggle-bar');
    const audioBtnBar = document.getElementById('audio-toggle-bar');
    const fullscreenBtn = document.getElementById('fullscreen-toggle-bar');
    const progressContainer = document.getElementById('progress-container');
    
    const iconPauseBar = document.getElementById('icon-pause-bar');
    const iconPlayBar = document.getElementById('icon-play-bar');
    const iconMutedBar = document.getElementById('icon-muted-bar');
    const iconPlayingBar = document.getElementById('icon-playing-bar');
    const iconFSEnter = document.getElementById('icon-fullscreen-enter');
    const iconFSExit = document.getElementById('icon-fullscreen-exit');
    
    const progressFill = document.getElementById('progress-fill');
    const timeDisplay = document.getElementById('time-display');

    let hasBeenClicked = false;
    let hideControlsTimeout;

    if (video && videoWrapper && controlsBar) {
        
        const resetControlsTimer = () => {
            if (!hasBeenClicked) return;

            controlsBar.classList.remove('fade-out');
            videoWrapper.classList.remove('hide-controls');
            
            clearTimeout(hideControlsTimeout);

            if (!video.paused) {
                hideControlsTimeout = setTimeout(() => {
                    controlsBar.classList.add('fade-out');
                    videoWrapper.classList.add('hide-controls');
                }, 3000);
            }
        };

        videoWrapper.addEventListener('mousemove', resetControlsTimer);
        videoWrapper.addEventListener('mouseenter', resetControlsTimer);
        videoWrapper.addEventListener('mouseleave', () => {
            if (hasBeenClicked && !video.paused) {
                controlsBar.classList.add('fade-out');
                videoWrapper.classList.add('hide-controls');
            }
        });

        videoWrapper.addEventListener('click', (e) => {
            if (e.target.closest('#custom-controls')) return;

            if (!hasBeenClicked) {
                video.currentTime = 0;
                video.muted = false;
                video.loop = false;

                controlsBar.classList.remove('initial-hide');
                
                iconMutedBar.classList.add('hidden');
                iconPlayingBar.classList.remove('hidden');
                
                video.play().catch(err => console.log("Error:", err));
                hasBeenClicked = true;
                resetControlsTimer();
            } else {
                togglePlay();
            }
        });

        const togglePlay = () => {
            if (video.paused) {
                video.play();
            } else {
                video.pause();
                clearTimeout(hideControlsTimeout);
                controlsBar.classList.remove('fade-out');
                videoWrapper.classList.remove('hide-controls');
            }
        };

        const updatePlayButtonState = () => {
            if (video.paused) {
                iconPauseBar.classList.add('hidden');
                iconPlayBar.classList.remove('hidden');
            } else {
                iconPauseBar.classList.remove('hidden');
                iconPlayBar.classList.add('hidden');
                resetControlsTimer();
            }
        };

        playBtnBar.addEventListener('click', togglePlay);

        audioBtnBar.addEventListener('click', () => {
            if (video.muted) {
                video.muted = false;
                iconMutedBar.classList.add('hidden');
                iconPlayingBar.classList.remove('hidden');
            } else {
                video.muted = true;
                iconMutedBar.classList.remove('hidden');
                iconPlayingBar.classList.add('hidden');
            }
        });

        progressContainer.addEventListener('click', (e) => {
            if (!video.duration) return;

            const rect = progressContainer.getBoundingClientRect();
            const clickX = e.clientX - rect.left;
            const percentage = clickX / rect.width;

            video.currentTime = percentage * video.duration;
            resetControlsTimer();
        });

        const toggleFullScreen = async () => {
            if (!document.fullscreenElement && !document.webkitFullscreenElement) {
                try {
                    if (videoWrapper.requestFullscreen) {
                        await videoWrapper.requestFullscreen();
                    } else if (videoWrapper.webkitRequestFullscreen) {
                        await videoWrapper.webkitRequestFullscreen();
                    } else if (videoWrapper.msRequestFullscreen) {
                        await videoWrapper.msRequestFullscreen();
                    }
                } catch (error) {
                    console.error("Error al ingresar a pantalla completa:", error);
                }
            } else {
                try {
                    if (document.exitFullscreen) {
                        await document.exitFullscreen();
                    } else if (document.webkitExitFullscreen) {
                        await document.webkitExitFullscreen();
                    } else if (document.msExitFullscreen) {
                        await document.msExitFullscreen();
                    }
                } catch (error) {
                    console.error("Error al salir de pantalla completa:", error);
                }
            }
        };

        fullscreenBtn.addEventListener('click', toggleFullScreen);

        const onFullscreenChange = () => {
            const isFullScreen = document.fullscreenElement || document.webkitFullscreenElement;
            
            if (isFullScreen) {
                iconFSEnter.classList.add('hidden');
                iconFSExit.classList.remove('hidden');
            } else {
                iconFSEnter.classList.remove('hidden');
                iconFSExit.classList.add('hidden');
            }
        };

        document.addEventListener('fullscreenchange', onFullscreenChange);
        document.addEventListener('webkitfullscreenchange', onFullscreenChange);

        video.addEventListener('timeupdate', () => {
            if (video.duration) {
                const percentage = (video.currentTime / video.duration) * 100;
                progressFill.style.width = `${percentage}%`;

                const timeLeft = video.duration - video.currentTime;
                const minutes = Math.floor(timeLeft / 60);
                const seconds = Math.floor(timeLeft % 60);
                timeDisplay.textContent = `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
            }
        });

        video.addEventListener('play', updatePlayButtonState);
        video.addEventListener('pause', updatePlayButtonState);
    }
</script>