---
import heroImage from '../../../assets/hero/HeroBackground.webp';
---

<section class="hero">
    <div class="text">
        <h1>Conquistando <br> salud y bienestar cada día</h1>
        <h2>Iniciativa independiente sin fines de lucro</h2>
    </div>

    <div class="video-container">
        <video 
            class="hero-video"
            autoplay 
            muted 
            loop 
            playsinline
            controlslist="nodownload"
        >
            <source src="/PropositoSerUno/HeroVideo.mp4" type="video/mp4" />
            Tu navegador no soporta el elemento video
        </video>
    </div>
</section>

<style define:vars={{ heroBg: `url(${heroImage.src})` }}>
    .hero {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start; 
        text-align: center;
        width: 100%;
        min-height: 96vh;
        padding: 74px 20px 160px 20px;
        color: var(--white);
        overflow: hidden; 
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: var(--heroBg);
        background-repeat: no-repeat;
        background-size: cover;
        background-position: bottom center;
        z-index: 0;
    }

    .text, .video-container {
        position: relative;
        z-index: 2;
    }

    h1 {
        font-weight: 600;
        font-size: clamp(42px, 5vw, 64.5px); 
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    
    h2 {
        font-weight: 400;
        font-size: clamp(22px, 2.5vw, 31.5px);
    }

    .video-container {
        position: absolute;
        top: 370px;
        width: 100%;
        max-width: 790px;
        aspect-ratio: 16 / 9;
        z-index: 10;
    }

    .hero-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    @media (max-width: 768px) {
        .video-container {
            position: absolute;
            top: auto; 
            top: 500px;
            width: 95%;
            max-width: 600px;
        }

        .hero::before {
            clip-path: inset(0 0 25vh 0);
        }

        .hero {
            margin-bottom: -25vh;
        }
    }

    @media (max-width: 1280px) {
        .hero {
            height: 118vh;
        }
    }
</style>