---
import { Image } from 'astro:assets';

import DesktopView from "../../../assets/Devices/DesktopView.webp";
import MobileView from "../../../assets/Devices/MobileView.webp";
---

<section class="access-device">
    <div class="container">
        <span class="eyebrow">ACCESO DISPONIBLE</span>

        <div class="content">
            <p>
                Ingresá desde tu celular, computadora o entorno virtual y avanzá a tu propio
                ritmo, donde y cuando lo desees.
            </p>
        </div>

        <div class="images">
            <Image src={MobileView} alt="Vista móvil de la plataforma Propósito Ser Uno" loading="lazy"/>
            <Image src={DesktopView} alt="Vista de escritorio de la plataforma Propósito Ser Uno" loading="lazy"/>
        </div>
</section>

<style>
    .access-device {
        background-color: var(--white);
        padding: 80px 20px 65px 20px;
        color: var(--text);
        display: flex;
        justify-content: center;
    }

    .container {
        max-width: 800px;
        width: 100%;
    }

    .eyebrow {
        display: block;
        font-family: var(--open-sans-font);
        color: var(--brand-700);
        font-weight: 600;
        font-size: 18px;
        letter-spacing: 1px;
        margin-bottom: 10px;
        text-transform: uppercase;
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 30px;
    }

    .content p {
        font-family: var(--open-sans-font);
        font-size: 21px;
        line-height: 1.6;
        font-weight: 400;
        color: var(--text);
        text-indent: 20px; 
        text-align: left;
    }

    .images {
        display: flex;
        gap: 30px;
        justify-content: center;
        width: 100%;
        margin-bottom: 30px;
    }

    .images img {
        width: 100%; 
        height: auto;
        flex: 1; 
        min-width: 0;
        object-fit: cover; 
    }

    @media (max-width: 768px) {
        .access-device { 
            padding: 40px 16px; 
        }

        .content p { 
            font-size: 18px;
            line-height: 1.6;
        }

        .images {
            flex-direction: column; 
            align-items: center;
        }
        
        .images img {
            width: 100%;
        }

        .eyebrow {
            margin-bottom: 15px;
        }
    }
</style>