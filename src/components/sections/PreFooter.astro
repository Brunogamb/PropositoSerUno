---
import { Image } from 'astro:assets';
import Logo from '../../assets/Logo.webp';
import Button from '../ui/Button.astro';
---

<section class="prefooter">
    <div class="container">
        <div class="content">
            <a href="/PropositoSerUno/"><Image src={Logo} alt="Logo" class="logo" loading="lazy"/></a>
            <h2>Comunidad en formación, hacia una organización civil sin fines de lucro</h2>
        </div>

        <div class="actions">
            <Button variant="primary" text="Hazte Miembro" href="/PropositoSerUno/membresia" className="small-btn" />
            <Button variant="outline" text="Explorar Programa" href="/PropositoSerUno/programa" className="small-btn" />
            <Button variant="primary" text="Fundadores" href="/PropositoSerUno/fundadores" className="small-btn" />
            <Button variant="secondary" text="Ver Comunidad" href="/PropositoSerUno/comunidad" className="small-btn" />
        </div>
    </div>
</section>

<style>
    .prefooter {
        background-color: var(--bg-section);
        padding: 100px 20px 24px 20px;
        color: var(--text);
        display: flex;
        justify-content: center;
    }

    .container {
        max-width: 1100px;
        width: 100%;
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 50px;
    }

    .content h2 {
        font-family: var(--open-sans-font);
        font-size: 30px;
        line-height: 1.6;
        font-weight: 400;
        color: var(--text-light);
        text-align: left;
    }

    .actions {
        display: flex;
        justify-content: space-between;
        width: 100%;
        flex-wrap: wrap;
        gap: 18px;
    }

    :global(.btn-base.small-btn) {
        padding-left: 32px;
        padding-right: 32px;
        padding-top: 10px;
        padding-bottom: 10px;
        font-size: 24px;
    }

    .logo {
        width: min(380px, 100%);
        height: auto;
    }

    a {
        width: fit-content;
    }

    @media (max-width: 1024px) {
        .prefooter {
            padding: 80px 20px 24px;
        }

        .content h2 {
            font-size: 26px;
            line-height: 1.55;
        }

        :global(.btn-base.small-btn) {
            font-size: 20px;
        }
    }

    @media (max-width: 768px) {
        .prefooter {
            padding: 52px 18px;
        }

        .content h2 {
            font-size: 22px;
            text-align: center;
            line-height: 1.4;
        }

        .actions {
            flex-direction: column;
            align-items: stretch;
            justify-content: center;
            gap: 14px;
        }

        :global(.btn-base.small-btn) {
            width: 100%;
            min-width: 0;
            padding-left: 18px;
            padding-right: 18px;
            font-size: 20px;
        }

        .content p {
            text-indent: 0;
        }
    }

    @media (max-width: 480px) {
        .prefooter {
            padding: 40px 16px;
        }

        .content h2 {
            font-size: 20px;
            line-height: 1.4;
        }

        :global(.btn-base.small-btn) {
            font-size: 18px;
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 12px;
            padding-bottom: 12px;
        }
    }
</style>