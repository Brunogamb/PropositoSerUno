---
import { Image } from 'astro:assets';
import logoMain from '../assets/Header/logo-main.webp';
import logoOrange from '../assets/Header/logo-orange.webp';
import logoOrangeLight from '../assets/Header/logo-orange-light.webp';
import logoOrangeWhite from '../assets/Header/logo-orange-white.webp'

interface Props {
    variant?: 'main' | 'orange' | 'orangeLight' | 'orangeWhite' | 'white';
}

const { variant = 'main' } = Astro.props;

const variants = {
    main: {
        bg: 'var(--brand-orange)',
        text: 'var(--brand-900)',
        logo: logoMain
    },
    orange: {
        bg: 'var(--bg-section)',
        text: 'var(--brand-orange-dark)', 
        logo: logoOrange 
    },
    orangeLight: {
        bg: 'var(--brand-900)',
        text: 'var(--brand-orange)', 
        logo: logoOrangeLight
    },
    orangeWhite: {
        bg: 'var(--brand-orange-darker)',
        text: 'var(--brand-orange-light)', 
        logo: logoOrangeWhite
    },
    white: {
        bg: 'var(--bg-section)',
        text: 'var(--brand-900)',
        logo: logoMain
    }
};

const current = variants[variant];
---

<header style={`background-color: ${current.bg}; --header-bg: ${current.bg}; --nav-color: ${current.text};`}>
    <div class="header-container">
        <a href="/PropositoSerUno/" class="header-logo" aria-label="Propósito Ser Uno - Inicio">
            <Image src={current.logo} alt="Logo de Propósito Ser Uno" class="logo logo-desktop" loading="eager" />
            <Image src={logoMain} alt="Logo de Propósito Ser Uno" class="logo logo-mobile" loading="eager" />
        </a> 

        <nav class="services-nav desktop-menu">
            <ul>
                <li><a href="/PropositoSerUno/programa">Programa</a></li>
                <li><a href="/PropositoSerUno/membresia">Membresía</a></li>
                <li><a href="/PropositoSerUno/comunidad">Comunidad</a></li>
                <li><a href="/PropositoSerUno/testimonios">Testimonios</a></li>
                <li><a href="/PropositoSerUno/fundadores">Fundadores</a></li>
            </ul>
        </nav>

        <div>
            <button class="hamburger" type="button" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="mobile-menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
        
        <nav class="services-nav mobile-menu" id="mobile-menu" aria-hidden="true">
            <ul>
                <li><a href="/PropositoSerUno/programa">Programa</a></li>
                <li><a href="/PropositoSerUno/membresia">Membresía</a></li>
                <li><a href="/PropositoSerUno/comunidad">Comunidad</a></li>
                <li><a href="/PropositoSerUno/testimonios">Testimonios</a></li>
                <li><a href="/PropositoSerUno/fundadores">Fundadores</a></li>
            </ul>
        </nav>
    </div>
</header>

<style>
header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 71px;
    gap: 20px;
    padding: 0 20px;
}

.header-container {
    max-width: 1140px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.header-logo {
    position: relative;
    height: 32px;
    z-index: 10000;
}

.desktop-menu {
    position: relative; 
    flex: 1;          
    display: flex;
    justify-content: center;
}

.header-container > div:last-of-type {
    flex: 0 0 300px; 
    display: flex;
    justify-content: flex-end;
}

.header-logo img {
    height: 100%;
    width: auto;
}

.logo-desktop {
    display: inline-block;
}

.logo-mobile {
    display: none;
}

.services-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 1200px;
}

.services-nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    margin: 10px 0 4px;   
    gap: 20px;
}

.services-nav a {
    color: var(--nav-color);
    font-family: var(--open-sans-font);
    font-weight: 600;
    font-size: 18px;
    display: flex;
    justify-content: center;
    gap: 8px;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.2s ease;
    letter-spacing: -0.1ch;
}

.hamburger {
    display: none;
    margin: auto;
}

.mobile-menu {
    display: none;
    position: absolute;
    top: 98%;
    left: 0;
    width: 100%;
    background: var(--header-bg);
    z-index: 15000;
    padding: 10px 20px 20px;
    animation: slideDown 0.25s ease forwards;
}

@media (hover: hover) {
    .services-nav a:hover {
        color: var(--brand-700);
    }
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 1160px) and (min-width: 769px) {
    .services-nav a {
        font-size: clamp(14px, 1.9vw, 18px);
        letter-spacing: -0.05ch;
    }

    .services-nav ul {
        gap: clamp(10px, 1.8vw, 16px);
    }

    .header-container {
        gap: 20px;
    }

    .header-logo {
        height: 28px;
    }
}

@media (max-width: 768px) {
    header {
        height: 65px;
        background-color: var(--white) !important;
        --header-bg: var(--white) !important;
        --nav-color: var(--brand-900) !important;
    }

    .header-logo {
        height: 28px;
    }

    .text {
        display: none;
    }

    .mobile-menu.active {
        display: flex;
    }

    .desktop-menu {
        display: none;
    }

    .header-container > div:last-of-type {
        flex: none; 
    }

    .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: space-around;
        width: 28px;
        height: 22px;
        background: transparent;
        border: none;
        cursor: pointer;
    }

    .hamburger span {
        width: 28px;
        height: 3px;
        border-radius: var(--radius-xs);
        transition: all 0.3s linear;
        transform-origin: 4px;
        background: var(--brand-900);
    }

    .hamburger.active span:nth-child(1) {
        transform: rotate(45deg);
    }

    .hamburger.active span:nth-child(2) {
        opacity: 0;
        transform: translateX(20px);
    }

    .hamburger.active span:nth-child(3) {
        transform: rotate(-45deg);
    }

    .mobile-menu ul {
        display: grid; 
        grid-template-columns: repeat(2, 1fr); 
    }

    .logo-desktop {
        display: none;
    }

    .logo-mobile {
        display: inline-block;
    }

    .mobile-menu li {
        width: 100%;
    }

    .mobile-menu li:last-child:nth-child(odd) {
        grid-column: 1 / span 2;
        width: max-content;
        margin: auto;
    }

    .mobile-menu a {
        justify-content: center;
        padding: 10px 20px;
        border: 1px solid rgba(0,0,0,0.08);
        border-radius: 8px;
        transition: background 0.2s ease;
        font-size: 18px;
        color: var(--brand-900);
        background: rgba(0,0,0,0.04);
    }

    .mobile-menu a:active {
        background: var(--brand-700);
        color: var(--white);
    }

    .mobile-menu .text {
        display: flex;
        font-size: 1.1rem;
        word-break: break-word;
        flex: 1;
    }
}
</style>

<script type="module">
    document.addEventListener('DOMContentLoaded', () => {
        const btnHamburger = document.querySelector('.hamburger');
        const mobileMenu = document.querySelector('.mobile-menu');
        const body = document.body;

        if (!btnHamburger || !mobileMenu) return;

        const toggleMenu = () => {
            const expanded = btnHamburger.getAttribute('aria-expanded') === 'true';
            btnHamburger.setAttribute('aria-expanded', (!expanded).toString());
            btnHamburger.setAttribute('aria-label', expanded ? 'Abrir menú de navegación' : 'Cerrar menú de navegación');
            btnHamburger.classList.toggle('active');
            mobileMenu.classList.toggle('active');
            mobileMenu.setAttribute('aria-hidden', expanded);
            body.classList.toggle('menu-open');
        };

        const closeMenu = () => {
            btnHamburger.setAttribute('aria-expanded', 'false');
            btnHamburger.setAttribute('aria-label', 'Abrir menú de navegación');
            btnHamburger.classList.remove('active');
            mobileMenu.classList.remove('active');
            mobileMenu.setAttribute('aria-hidden', 'true');
            body.classList.remove('menu-open');
        };

        btnHamburger.addEventListener('click', toggleMenu);

        document.addEventListener('click', (e) => {
            if (mobileMenu.classList.contains('active') && 
                !mobileMenu.contains(e.target) && 
                !btnHamburger.contains(e.target)) {
                closeMenu();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mobileMenu.classList.contains('active')) {
                closeMenu();
            }
        });
    });
</script>