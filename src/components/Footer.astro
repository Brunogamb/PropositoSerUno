<footer>
    <div class="footer-content">
        <a href="#" class="disabled" aria-disabled="true" onclick="event.preventDefault()">Redes Sociales</a>
        <a href="/PropositoSerUno/aviso-legal">Aviso Legal</a>
        <a href="mailto:administracion@propositoseruno.com">e-mails de PSU</a>
    </div>

    <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Propósito Ser Uno.</p>
        <p class="dev">Desarrollado por <a href="https://brunogamb.github.io/CVDEV/" target="_blank" rel="noopener noreferrer">BrunoGamb</a>
        </p>
    </div>
</footer>

<style>
footer {
    background: var(--brand-900);
    box-shadow: var(--shadow-top);
    display: flex;
    flex-direction: column; 
    align-items: center;
    justify-content: center;
    color: var(--white);
    text-wrap: balance;
    border-bottom: 13px solid var(--brand-orange-dark);
    padding: 0 20px 10px;
}

.footer-content {
    display: flex;
    gap: 150px;
    max-width: 1100px;
    width: 100%;
    padding: 46px 0 130px;
    font-weight: 500;
    font-family: var(--open-sans-font);
}

.footer-content a {
    position: relative;
    font-size: 24px;
    height: fit-content;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
}

.footer-content a.disabled {
    cursor: not-allowed;
    border-bottom-color: transparent;
}

.footer-content a.disabled:hover,
.footer-content a.disabled:focus-visible {
    color: rgba(var(--white-rgb), 0.7);
    border-bottom-color: transparent;
}

.footer-content a.disabled::after {
    content: "Próximamente";
    position: absolute;
    left: 50%;
    bottom: -2.4rem;
    transform: translateX(-50%) translateY(6px);
    opacity: 0;
    white-space: nowrap;
    pointer-events: none;
    background: rgba(var(--black-rgb), 0.9);
    color: var(--white);
    font-size: 0.85rem;
    padding: 6px 10px;
    border-radius: 999px;
    transition: opacity 0.2s ease, transform 0.2s ease;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
    z-index: 1;
}

.footer-content a.disabled:hover::after,
.footer-content a.disabled:focus-visible::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
}

.footer-bottom {
    display: flex;
    justify-content: space-between; 
    width: 100%;
    max-width: 1100px;
    font-size: 14px;
    font-family: var(--open-sans-font);
    color: rgba(var(--white-rgb), 0.6);
}

.dev a {
    font-weight: 600;
    font-size: 15px;
    border-bottom: 1px solid rgba(var(--white-rgb), 0.6);
}

@media (hover: hover) {
    footer a:hover {
        color: var(--brand-orange);
        border-bottom-color: var(--brand-orange);
    }

    .dev a:hover {
        border-bottom-width: 2px;
    }
}

@media (max-width: 768px) {
    .footer-content {
        flex-direction: column;
        gap: 40px;
        text-align: center;
        padding: 40px 20px;
    }

    .footer-content a.disabled::after {
        font-size: 20px;
        padding: 5px 8px;
        top: 30px;
    }

    .footer-bottom {
        flex-direction: column;
        text-align: center;
        gap: 10px;
    }
}
</style>